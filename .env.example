# Automation environment.
# Copy to .env and fill in locally. .env is gitignored.

# If `gh auth status` is already clean, leaving GITHUB_TOKEN empty is fine —
# the app shells out to gh and inherits its auth. Set it explicitly only if
# you run the loop from a context where gh is not authenticated.
GITHUB_TOKEN=

# Override if `claude` is not on PATH for the launchd user context.
# CLAUDE_BIN=/Users/user/.local/bin/claude
